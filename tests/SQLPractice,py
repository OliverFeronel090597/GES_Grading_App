import sys
import os
from PyQt6.QtWidgets import (
    QApplication, QWidget, QVBoxLayout, QHBoxLayout, QPlainTextEdit,
    QPushButton, QLabel, QTableView, QSplitter, QCompleter
)
from PyQt6.QtGui import QFont, QColor, QTextCharFormat, QSyntaxHighlighter, QTextCursor
from PyQt6.QtCore import Qt, QRegularExpression, QStringListModel
from PyQt6.QtSql import QSqlDatabase, QSqlQueryModel

DB_PATH = os.path.join("db", "school.db")


# ---------------------------
# SQL Syntax Highlighter
# ---------------------------
class SqlHighlighter(QSyntaxHighlighter):
    KEYWORDS = [
        'SELECT', 'FROM', 'WHERE', 'LEFT', 'JOIN', 'ON', 'ORDER', 'BY', 'ASC', 'DESC',
        'INSERT', 'INTO', 'VALUES', 'UPDATE', 'SET', 'DELETE', 'CREATE', 'TABLE', 'IF',
        'NOT', 'NULL', 'PRIMARY', 'KEY', 'FOREIGN'
    ]

    def __init__(self, parent):
        super().__init__(parent)
        self.keyword_format = QTextCharFormat()
        self.keyword_format.setForeground(QColor("#FF6F61"))
        self.keyword_format.setFontWeight(QFont.Weight.Bold)

        self.string_format = QTextCharFormat()
        self.string_format.setForeground(QColor("#6A8759"))

        self.comment_format = QTextCharFormat()
        self.comment_format.setForeground(QColor("#808080"))
        self.comment_format.setFontItalic(True)

    def highlightBlock(self, text):
        # Keywords
        for word in self.KEYWORDS:
            pattern = QRegularExpression(f"\\b{word}\\b", QRegularExpression.PatternOption.CaseInsensitiveOption)
            it = pattern.globalMatch(text)
            while it.hasNext():
                match = it.next()
                self.setFormat(match.capturedStart(), match.capturedLength(), self.keyword_format)

        # Strings
        string_pattern = QRegularExpression("'.*?'")
        it = string_pattern.globalMatch(text)
        while it.hasNext():
            match = it.next()
            self.setFormat(match.capturedStart(), match.capturedLength(), self.string_format)

        # Comments
        comment_index = text.find("--")
        if comment_index != -1:
            self.setFormat(comment_index, len(text) - comment_index, self.comment_format)


# ---------------------------
# QPlainTextEdit with Completer
# ---------------------------
class SqlEdit(QPlainTextEdit):
    def __init__(self, words, parent=None):
        super().__init__(parent)
        self.completer = QCompleter(words, self)
        self.completer.setCaseSensitivity(Qt.CaseSensitivity.CaseInsensitive)
        self.completer.setWidget(self)
        self.completer.activated.connect(self.insert_completion)

    def insert_completion(self, text):
        tc = self.textCursor()
        extra = len(text) - len(self.completer.completionPrefix())
        tc.movePosition(QTextCursor.MoveOperation.Left, QTextCursor.MoveMode.KeepAnchor, len(self.completer.completionPrefix()))
        tc.insertText(text)
        self.setTextCursor(tc)

    def keyPressEvent(self, event):
        super().keyPressEvent(event)
        cursor = self.textCursor()
        cursor.select(QTextCursor.SelectionType.WordUnderCursor)
        word = cursor.selectedText()
        if len(word) >= 1:
            self.completer.setCompletionPrefix(word)
            cr = self.cursorRect()
            cr.setWidth(self.completer.popup().sizeHintForColumn(0) +
                        self.completer.popup().verticalScrollBar().sizeHint().width())
            self.completer.complete(cr)


# ---------------------------
# Main Application
# ---------------------------
class SQLPracticeApp(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("SQLite SQL Practice")
        self.resize(1200, 700)

        splitter = QSplitter(Qt.Orientation.Horizontal)
        self.layout = QHBoxLayout(self)
        self.layout.addWidget(splitter)

        # Left: SQL input
        left_widget = QWidget()
        left_layout = QVBoxLayout(left_widget)
        splitter.addWidget(left_widget)

        left_layout.addWidget(QLabel("Enter SQL Query (multiple queries separated by ';')"))

        # Words for autocomplete (tables + columns)
        words = [
            "Students", "Subjects", "Grades",
            "ID", "Name", "Guardian", "SchoolYear", "GradeLevel",
            "Subject", "Advisor", "StudentID", "SubjectID", "Section", "Grade"
        ]
        self.sql_input = SqlEdit(words)
        self.sql_input.setFont(QFont("Courier", 10))
        left_layout.addWidget(self.sql_input)

        self.run_btn = QPushButton("Run Query")
        self.run_btn.clicked.connect(self.run_query)
        left_layout.addWidget(self.run_btn)

        SqlHighlighter(self.sql_input.document())

        # Right: Query results
        right_widget = QWidget()
        right_layout = QVBoxLayout(right_widget)
        splitter.addWidget(right_widget)

        self.label_results = QLabel("Query Results:")
        right_layout.addWidget(self.label_results)

        self.table_view = QTableView()
        right_layout.addWidget(self.table_view)

        # Database
        self.db = QSqlDatabase.addDatabase("QSQLITE")
        self.db.setDatabaseName(DB_PATH)
        if not self.db.open():
            self.label_results.setText(f"Failed to open DB: {self.db.lastError().text()}")
            return

        self.model = QSqlQueryModel()
        self.table_view.setModel(self.model)

        # QSS
        self.setStyleSheet("""
            QWidget { background-color: #2B2B2B; color: #FFFFFF; font-family: Consolas; font-size: 12px; }
            QPlainTextEdit { background-color: #313335; color: #FFFFFF; border: 1px solid #555555; }
            QTableView { background-color: #313335; color: #FFFFFF; gridline-color: #555555; }
            QPushButton { background-color: #FF6F61; color: #FFFFFF; border-radius: 5px; padding: 5px; }
            QPushButton:hover { background-color: #FF8F7A; }
        """)

    def run_query(self):
        text = self.sql_input.toPlainText().strip()
        if not text:
            return

        # Split multiple queries
        queries = [q.strip() for q in text.split(";") if q.strip()]
        for q in queries:
            self.model.setQuery(q, self.db)
            if self.model.lastError().isValid():
                self.label_results.setText(f"Query Error: {self.model.lastError().text()}")
            else:
                self.label_results.setText("Query Results:")
                self.table_view.resizeColumnsToContents()


if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = SQLPracticeApp()
    window.show()
    sys.exit(app.exec())
